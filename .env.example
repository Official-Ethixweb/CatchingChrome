# Live river conditions for the fishing calendar's "today" outlook.
# Get a free key at https://openweathermap.org/api (Current Weather Data).
# Copy this file to `.env` and paste your key below.
OPENWEATHER_API_KEY=

# Live Google reviews for the Client Log carousel.
# Needs "Places API (New)" enabled on a billing-enabled Google Cloud project:
# https://console.cloud.google.com/apis/library/places.googleapis.com
# Without it the Client Log falls back to the curated reviews in
# src/lib/googleReviews.ts.
GOOGLE_PLACES_API_KEY=

# Contact form delivery via SMTP2GO. REQUIRED for the form to actually reach
# Ryan — without the key + to-address the form cannot send, and tells the guest
# to call or email instead (it never claims to have sent).
# 1. Create a key at SMTP2GO → Settings → API Keys (starts with "api-...").
# 2. CONTACT_TO_EMAIL is the inbox enquiries land in.
# 3. CONTACT_FROM_EMAIL must be an address on the SMTP2GO-verified sender
#    domain (catchingchromeguideservice.com). If unset it defaults to
#    noreply@catchingchromeguideservice.com.
SMTP2GO_API_KEY=
CONTACT_TO_EMAIL=ryanbfishin@gmail.com
CONTACT_FROM_EMAIL=noreply@catchingchromeguideservice.com

# Contact-form bot protection — Google reCAPTCHA v2 ("I'm not a robot" checkbox).
# Create keys at https://www.google.com/recaptcha/admin/create
#   • Type: reCAPTCHA v2 → "I'm not a robot" Checkbox
#   • Domains: catchingchromeguideservice.com  AND  localhost (for testing)
# The SITE key is public (ships to the browser, hence the VITE_ prefix); the
# SECRET key stays server-side. The checkbox only shows when the SITE key is
# set, and the server only enforces it when the SECRET key is set — so set BOTH
# to turn protection on. Leave both blank to keep the form open (no captcha).
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
