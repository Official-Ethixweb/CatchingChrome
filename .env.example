# Live river conditions for the fishing calendar's "today" outlook.
# Get a free key at https://openweathermap.org/api (Current Weather Data).
# Copy this file to `.env` and paste your key below.
OPENWEATHER_API_KEY=

# Live Google reviews for the Client Log carousel.
# Needs "Places API (New)" enabled on a billing-enabled Google Cloud project:
# https://console.cloud.google.com/apis/library/places.googleapis.com
# Without it the Client Log falls back to the curated reviews in
# src/lib/googleReviews.ts.
GOOGLE_PLACES_API_KEY=
